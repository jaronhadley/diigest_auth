:{$PORT} {
    # 1. Open the API paths for your Python SDK Workers
    @api_paths {
        path /e/*
        path /api/*
    }

    # 2. Open WebSockets (Fixes the infinite auth loop)
    @websockets {
        header Connection *Upgrade*
        header Upgrade websocket
    }

    # 3. Apply the password ONLY to standard Dashboard HTTP traffic
    @dashboard {
        not path /e/*
        not path /api/*
        not header Connection *Upgrade*
    }

    basicauth @dashboard {
        {$UI_USERNAME} {$UI_PASSWORD_HASH}
    }

    # 4. Forward everything to your hidden Inngest server
    reverse_proxy http://inngest.railway.internal:8288
}