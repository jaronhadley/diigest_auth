:{$PORT} {
    # 1. Open WebSockets (Fixes the initial socket loop)
    @websockets {
        header Connection *Upgrade*
        header Upgrade websocket
    }

    # 2. Apply the password ONLY to the root HTML and secure routes
    # We add /_next/* and /favicon.ico to the exclusion list
    @dashboard {
        not path /e/*
        not path /api/*
        not path /_next/*
        not path /favicon.ico
        not header Connection *Upgrade*
    }

    basicauth @dashboard {
        {$UI_USERNAME} {$UI_PASSWORD_HASH}
    }

    # 3. Forward everything to your hidden Inngest server
    reverse_proxy http://inngest.railway.internal:8288
}