:{$PORT} {
    # 1. Intercept the UI's test events and inject your real key
    rewrite /e/dev_key /e/{$EVENT_KEY}

    # 2. THE FIX: Catch the React app's /dev request and mock a success!
    @dev_flags path /dev*
    handle @dev_flags {
        respond `{"flags": {}}` 200
    }

    # 3. Allow Python SDKs and events to connect freely
    @sdk_traffic {
        path /e/*
        path /api/*
    }
    handle @sdk_traffic {
        reverse_proxy http://inngest.railway.internal:8288
    }

    # 4. Allow WebSockets (for both SDKs and UI live-streaming)
    @websockets {
        header Connection *Upgrade*
        header Upgrade websocket
    }
    handle @websockets {
        reverse_proxy http://inngest.railway.internal:8288
    }

    # 5. The Magic Login Endpoint
    @unlock path /unlock/{$SECRET_LOGIN_PATH}
    handle @unlock {
        header Set-Cookie "inngest_auth=granted; Path=/; Max-Age=2592000; HttpOnly; SameSite=Lax"
        redir * /
    }

    # 6. Check for the Cookie on all other UI traffic
    @has_cookie header Cookie *inngest_auth=granted*
    handle @has_cookie {
        reverse_proxy http://inngest.railway.internal:8288
    }

    # 7. Catch-All: Block everything else
    handle {
        respond "Unauthorized - Please use your secure login link." 401
    }
}